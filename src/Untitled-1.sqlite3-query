select * from questions 
ORDER BY question_text, correct_answer
LIMIT 2;

SELECT q.question_text, r.is_correct 
FROM results AS r
INNER JOIN users AS u
    ON u.id = r.user_id
INNER JOIN questions AS q
    ON q.id = r.question_id

WHERE r.user_id = 1
ORDER BY r.id DESC



